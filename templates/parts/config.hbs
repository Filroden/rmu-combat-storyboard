<div class="rmu-combat-narrator-main {{#if (eq state.activeTab 'config')}}active{{/if}}" data-tab="config" data-group="primary">
    
    <fieldset class="rmu-combat-narrator-fieldset">
        <legend>{{localize "RMU_NARRATOR.Wizard.Tabs.Config"}}</legend>

        <div class="form-group">
            <label>{{localize "RMU_NARRATOR.Wizard.Labels.LogSelection"}}</label>
            <div class="form-fields">
                <select name="selectedLogId">
                    <option value="" disabled {{#unless state.selectedLogId}}selected{{/unless}}>{{localize "RMU_NARRATOR.Wizard.Placeholders.SelectLog"}}</option>
                    {{#each availableLogs}}
                        <option value="{{this.id}}" {{#if (eq ../state.selectedLogId this.id)}}selected{{/if}}>{{this.name}}</option>
                    {{/each}}
                </select>
            </div>
            <p class="notes">{{localize "RMU_NARRATOR.Wizard.Hints.LogSelection"}}</p>
        </div>
        
        <div class="form-group">
            <label>{{localize "RMU_NARRATOR.Wizard.Labels.PromptStyle"}}</label>
            <div class="form-fields">
                <select name="promptStyle">
                    <option value="text" {{#if (eq state.promptStyle "text")}}selected{{/if}}>{{localize "RMU_NARRATOR.Wizard.Options.PromptStyleText"}}</option>
                    <option value="image" {{#if (eq state.promptStyle "image")}}selected{{/if}}>{{localize "RMU_NARRATOR.Wizard.Options.PromptStyleImage"}}</option>
                    <option value="autodraw" {{#if (eq state.promptStyle "autodraw")}}selected{{/if}}>{{localize "RMU_NARRATOR.Wizard.Options.PromptStyleAuto"}}</option>
                </select>
            </div>
            <p class="notes">{{localize "RMU_NARRATOR.Wizard.Hints.PromptStyle"}}</p>
        </div>

        <div class="form-group">
            <label>{{localize "RMU_NARRATOR.Wizard.Labels.ArtStyle"}}</label>
            <div class="form-fields">
                <select name="artStyle">
                    <option value="gritty" {{#if (eq state.artStyle "gritty")}}selected{{/if}}>{{localize "RMU_NARRATOR.Wizard.Options.ArtStyleGritty"}}</option>
                    <option value="manga" {{#if (eq state.artStyle "manga")}}selected{{/if}}>{{localize "RMU_NARRATOR.Wizard.Options.ArtStyleManga"}}</option>
                    <option value="pop" {{#if (eq state.artStyle "pop")}}selected{{/if}}>{{localize "RMU_NARRATOR.Wizard.Options.ArtStylePop"}}</option>
                </select>
            </div>
            <p class="notes">{{localize "RMU_NARRATOR.Wizard.Hints.ArtStyle"}}</p>
        </div>

        <div class="form-group">
            <label>{{localize "RMU_NARRATOR.Wizard.Labels.PageTarget"}}</label>
            <div class="form-fields">
                <input type="number" name="pageTarget" value="{{state.pageTarget}}" min="1" max="10" step="1">
            </div>
            <p class="notes">{{localize "RMU_NARRATOR.Wizard.Hints.PageTarget"}}</p>
        </div>
    </fieldset>

    <fieldset class="rmu-combat-narrator-fieldset">
        <legend>{{localize "RMU_NARRATOR.Wizard.Labels.CampaignContext"}}</legend>
        <div class="form-group stacked">
            <label>{{localize "RMU_NARRATOR.Wizard.Labels.Atmosphere"}}</label>
            <textarea name="campaignContext" rows="4" placeholder="{{localize 'RMU_NARRATOR.Wizard.Placeholders.CampaignContext'}}">{{state.campaignContext}}</textarea>
            <p class="notes">{{localize "RMU_NARRATOR.Wizard.Hints.CampaignContext"}}</p>
        </div>
    </fieldset>

</div>